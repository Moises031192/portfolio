---
import PortfolioLayout from '../layouts/PortfolioLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';

const ORIGIN = (Astro.site ?? new URL('https://www.mrmoises.es')).href;
const url = new URL(Astro.url.pathname, ORIGIN).href;
const projects = [
  { slug: 'estudioarquo', name: 'Estudio Arquó — escaparate digital de arquitectura' },
  { slug: 'akra-restaurante', name: 'Akra Restaurante — UX y behavioral design' },
  { slug: 'basica-co', name: 'Basica & Co — e-commerce de moda' },
  { slug: 'huntingtallares', name: 'Hunting Tallares — behavioral design' },
  { slug: 'lulas-lulas', name: 'Lulàs_Lulàs — e-commerce de joyería' },
];
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${url}#collectionpage`,
    url,
    name: 'Proyectos — Moisés Salmán',
    inLanguage: 'es-ES',
    isPartOf: { '@id': `${ORIGIN}#website` },
    about: { '@id': `${ORIGIN}#person` },
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: projects.map((p, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `${ORIGIN}${p.slug}`,
        name: p.name,
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: ORIGIN },
      { '@type': 'ListItem', position: 2, name: 'Proyectos', item: url },
    ],
  },
];
---

<PortfolioLayout
  title="Proyectos — Moisés Salmán, product designer"
  description="Casos de diseño de producto centrados en growth y conversión: e-commerce, restauración, moda y arquitectura. Proyectos que he ayudado a crecer."
  ogImage="/images/Moises-portada.webp"
  bodyClass="bg-base-black"
  schema={schema}
>
  <Nav />
  <div class="proyectos-cascada hero-section">
    <div class="container-14">
      <h1 class="headline-big medium-width centered medium-spacing fade-in">Proyectos que he ayudado a crecer</h1>
      <a href="/estudioarquo" class="proyect-card__full large-spacing w-inline-block">
        <div class="img_wrapper _7-height"><img src="/images/visualelectric-4_1.avif" loading="lazy" sizes="(max-width: 2816px) 100vw, 2816px" srcset="/images/visualelectric-4_1-p-500.avif 500w, /images/visualelectric-4_1-p-800.avif 800w, /images/visualelectric-4_1-p-1080.avif 1080w, /images/visualelectric-4_1-p-1600.avif 1600w, /images/visualelectric-4_1-p-2000.avif 2000w, /images/visualelectric-4_1-p-2600.avif 2600w, /images/visualelectric-4_1.avif 2816w" alt="Proyecto Estudio Arquó — escaparate digital de arquitectura" class="image-project _7-height" /></div>
        <div class="container-7 fade-in">
          <div class="wysiwyg">Diseño + Desarrollo Web</div>
          <h4 class="project-title">Estudio Arquó</h4>
          <p class="project-subtitle">Arquitectura con alma<br /></p>
        </div>
      </a>
      <div data-w-id="c751f376-0ff5-d0e8-6714-e81a34eeb73c" class="proyect-row last-child">
        <a href="/akra-restaurante" class="proyect-card_6 margin_top_2 w-inline-block">
          <div class="img_wrapper size_6_6"><img src="/images/_uvs1j3vxv35zghkgnv0o_1.avif" loading="lazy" sizes="(max-width: 1024px) 100vw, 1024px" srcset="/images/_uvs1j3vxv35zghkgnv0o_1-p-500.avif 500w, /images/_uvs1j3vxv35zghkgnv0o_1-p-800.avif 800w, /images/_uvs1j3vxv35zghkgnv0o_1.avif 1024w" alt="Proyecto Akra Restaurante — restauración mediterránea" class="image-project size_6_6 fade-in" /></div>
          <div class="container-5 fade-in">
            <div class="wysiwyg">Diseño + Desarrollo Web</div>
            <h4 class="project-title">Akra restaurante</h4>
            <p class="project-subtitle">Restauración mediterránea<br /></p>
          </div>
        </a>
        <a href="/basica-co" class="proyect-card-5 no-margin-bottom w-inline-block">
          <div class="img_wrapper size5-4"><img src="/images/hero-image_1.avif" loading="lazy" sizes="(max-width: 1792px) 100vw, 1792px" srcset="/images/hero-image_1hero-image.avif 500w, /images/hero-image_1hero-image.avif 800w, /images/hero-image_1.avif 1792w" alt="Basica & Co, e-commerce de moda urbana femenina" class="image-project fade-in" /></div>
          <div class="container-5 fade-in">
            <div class="wysiwyg">E-commerce</div>
            <h4 class="project-title">Basica &amp; Co</h4>
            <p class="project-subtitle">Moda urbana para mujeres<br /></p>
          </div>
        </a>
      </div>
      <div data-w-id="c751f376-0ff5-d0e8-6714-e81a34eeb753" class="proyect-row">
        <a href="/huntingtallares" class="proyect-card_6 margin_top_2 w-inline-block">
          <div class="img_wrapper size_6_6"><img src="/images/caza_menor.avif" loading="lazy" sizes="(max-width: 1440px) 100vw, 1440px" srcset="/images/caza_menor-p-500.avif 500w, /images/caza_menor-p-800.avif 800w, /images/caza_menor-p-1080.avif 1080w, /images/caza_menor.avif 1440w" alt="Proyecto Hunting Tallares — referencia nacional de caza" class="image-project size_6_6 fade-in" /></div>
          <div class="container-5 fade-in">
            <div class="wysiwyg">Web marketing</div>
            <h4 class="project-title">Hunting Tallares</h4>
            <p class="project-subtitle">Referencia nacional caza<br /></p>
          </div>
        </a>
        <a href="/lulas-lulas" class="proyect-card-5 w-inline-block">
          <div class="img_wrapper size5-4"><img src="/images/collardoradolulas_1.avif" loading="lazy" sizes="(max-width: 990px) 100vw, 990px" srcset="/images/collardoradolulas_1collardoradolulas.avif 500w, /images/collardoradolulas_1.avif 990w" alt="Proyecto Lulàs_Lulàs — joyería personalizada para mujer" class="image-project fade-in" /></div>
          <div class="container-5 fade-in">
            <div class="wysiwyg">E-commerce</div>
            <h4 class="project-title">Lulas-Lulas</h4>
            <p class="project-subtitle">Joyería para mujer<br /></p>
          </div>
        </a>
      </div>
      <a data-w-id="c751f376-0ff5-d0e8-6714-e81a34eeb76a" href="/proyectos" aria-current="page" class="cta base__white centered w-inline-block w--current">
        <p class="wysiwyg cta-text dark__type">Ver proyectos</p>
        <div class="cta-circle"></div>
      </a>
    </div>
    <BottomNav />
  </div>
  <Footer />
  <BottomNav />
</PortfolioLayout>
