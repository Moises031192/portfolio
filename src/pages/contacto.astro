---
import PortfolioLayout from '../layouts/PortfolioLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
---

<PortfolioLayout
  title="Contacto"
  description="Contacto"
  ogImage="/images/Moises-portada.webp"
  bodyClass="bg-base-black"
>
  <Nav />
  <div class="hero-section">
    <h1 class="heading centered fade-in">Siéntete libre <br />de escribirme</h1>
    <div class="form-block w-form">
      <form id="email-form" name="email-form" data-name="Email Form" method="POST" action="/api/contact" class="fade-in">
        <input type="text" name="company" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;" />
        <div class="form-field-row">
          <div class="form-field-wrapper"><label for="name" class="field-label">Nombre</label><input class="field-text w-input" maxlength="256" name="name" data-name="Name" placeholder="" type="text" id="name" required /></div>
          <div class="form-field-wrapper"><label for="apellidos-2" class="field-label">Apellidos</label><input class="field-text w-input" maxlength="256" name="apellidos" data-name="apellidos" placeholder="" type="text" id="apellidos-2" required /></div>
        </div>
        <div class="form-field-row">
          <div class="form-field-wrapper"><label for="email-2" class="field-label">Email</label><input class="field-text w-input" maxlength="256" name="email" data-name="email" placeholder="" type="email" id="email-2" required /></div>
          <div class="form-field-wrapper"><label for="telefono-2" class="field-label">Teléfono</label><input class="field-text w-input" maxlength="256" name="telefono" data-name="telefono" placeholder="" type="tel" id="telefono-2" required /></div>
        </div>
        <div class="form-field-row">
          <div class="form-field-wrapper full-size"><select id="field" name="field" data-name="Field" class="field-text selection w-select">
              <option value="">Seleccione uno</option>
              <option value="First">Me gustaría proponerte un proyecto</option>
              <option value="Second">Me gustaría poder realizar una entrevista contigo</option>
              <option value="Third">Me gustaría concertar una mentoría</option>
            </select><label for="email-3" class="field-label">Selecciona el motivo de su consulta</label></div>
        </div><input type="submit" data-wait="Please wait..." class="submit-button w-button" value="Contacta conmigo" />
      </form>
      <div class="success-message w-form-done">
        <div class="wysiwyg">Muchas gracias, me pondré en contacto contigo a la mayor brevedad.</div>
      </div>
      <div class="error-message w-form-fail">
        <div class="wysiwyg">Upps, parece que algo no fue bien, intenta enviar el mensaje de nuevo</div>
      </div>
    </div>
  </div>
  <Footer />
  <BottomNav />
</PortfolioLayout>

<style is:global>
  input.input-box,
  textarea {
    background: white;
    color: black;
  }
  .w-input::-webkit-input-placeholder {
    color: #ffffff;
  }
  .w-input:-moz-placeholder {
    color: #ffffff;
    opacity: 1;
  }
  .w-input::-moz-placeholder {
    color: #ffffff;
    opacity: 1;
  }
  .w-input:-ms-input-placeholder {
    color: #ffffff;
  }
  input.black-text,
  textarea {
    color: #ffffff;
  }
</style>

<script>
  // Submit to the secure server endpoint, then show Webflow's done/fail states.
  const form = document.getElementById('email-form') as HTMLFormElement | null;
  if (form) {
    const block = form.closest('.w-form');
    const done = block?.querySelector<HTMLElement>('.w-form-done');
    const fail = block?.querySelector<HTMLElement>('.w-form-fail');
    const submit = form.querySelector<HTMLInputElement>('input[type="submit"]');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const original = submit?.value;
      if (submit) {
        submit.disabled = true;
        submit.value = submit.getAttribute('data-wait') || 'Enviando...';
      }
      if (fail) fail.style.display = 'none';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (!res.ok) throw new Error('Request failed');

        form.style.display = 'none';
        if (done) done.style.display = 'block';
      } catch {
        if (fail) fail.style.display = 'block';
        if (submit) {
          submit.disabled = false;
          submit.value = original || 'Contacta conmigo';
        }
      }
    });
  }
</script>
