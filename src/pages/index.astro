  <style>
    /* Carrusel infinito de logos: avanza de izquierda a derecha,
       lineal y a velocidad constante. Se pausa al hacer hover. */
    .carousel_wrapper {
      width: 100vw;
      overflow: hidden;
    }

    .carousel-row {
      width: max-content;
      flex-wrap: nowrap;
      animation: logos-scroll 40s linear infinite;
      will-change: transform;
    }

    /* Cada track replica los mismos logos; el desplazamiento del -50%
       equivale a un track completo, logrando un bucle sin saltos. */
    .logo_container {
      flex: 0 0 auto;
      padding-right: 40px; /* mantiene la separación uniforme en la unión */
    }

    .carousel_wrapper:hover .carousel-row {
      animation-play-state: paused;
    }

    @keyframes logos-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    @media (prefers-reduced-motion: reduce) {
      .carousel-row {
        animation: none;
      }
    }

    /* --- Sección Referencias: fondo negro + texto blanco --- */
    .reference-section {
      background-color: var(--base--black, #101010);
    }

    .reference-section .base__black {
      color: #fff;
    }

    /* Líneas (superior e inferior de cada bloque). Arrancan colapsadas en el
       centro y se expanden hacia los lados vía JS (scaleX 0 -> 1). */
    .reference-section .separator-line {
      width: 100%;
      height: 2px;
      transform: scaleX(0);
      transform-origin: center;
      background-image: linear-gradient(
        to right,
        rgba(255, 255, 255, 0),
        rgba(255, 255, 255, 0.85) 50%,
        rgba(255, 255, 255, 0)
      );
      will-change: transform;
    }

    @media (prefers-reduced-motion: reduce) {
      .reference-section .separator-line {
        transform: scaleX(1);
      }
    }
  </style>

  <script>
    // Líneas de la sección Referencias: se expanden del centro a los lados
    // (scaleX 0 -> 1) al entrar en viewport. 0.9s, power4.out.
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    const lines = gsap.utils.toArray<HTMLElement>(
      '.reference-section .separator-line'
    );

    if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.set(lines, { scaleX: 1 });
    } else {
      lines.forEach((line) => {
        gsap.fromTo(
          line,
          { scaleX: 0 },
          {
            scaleX: 1,
            duration: 0.9,
            ease: 'power4.out',
            scrollTrigger: {
              trigger: line,
              start: 'top 90%',
              once: true,
            },
          }
        );
      });
    }
  </script>
</PortfolioLayout>
