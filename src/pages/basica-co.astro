---
import PortfolioLayout from '../layouts/PortfolioLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';

const ORIGIN = (Astro.site ?? new URL('https://www.mrmoises.es')).href;
const url = new URL(Astro.url.pathname, ORIGIN).href;
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    '@id': `${url}#project`,
    url,
    name: 'Basica & Co — e-commerce de moda',
    headline: 'Basica & Co — e-commerce de moda',
    inLanguage: 'es-ES',
    image: `${ORIGIN}images/hero-image_1.avif`,
    creator: { '@id': `${ORIGIN}#person` },
    author: { '@id': `${ORIGIN}#person` },
    about: 'E-commerce de moda urbana femenina',
    keywords: ['E-commerce Design', 'Behavioral design', 'UX/UI', 'Moda'],
    isPartOf: { '@id': `${ORIGIN}#website` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: ORIGIN },
      { '@type': 'ListItem', position: 2, name: 'Proyectos', item: `${ORIGIN}proyectos` },
      { '@type': 'ListItem', position: 3, name: 'Basica & Co', item: url },
    ],
  },
];
---

<PortfolioLayout
  title="Basica&Co — e-commerce de moda | Moisés Salmán"
  description="Caso de estudio: e-commerce de moda urbana femenina con behavioral design, equilibrando impacto visual de marca y una UX optimizada para conversión."
  ogImage="/images/Moises-portada.webp"
  bodyClass="body"
  schema={schema}
>
  <Nav />
  <section class="hero_project">
    <div class="hero_project_contain">
      <h1 class="hero_project_heading heading text-colour-white fade-in">Basica &amp; CO Fashion design</h1>
      <div class="u-hflex-between-center fade-in hero_project_subtitle-cta">
        <div class="hero_project_tipology text-colour-white">E-Commerce Design</div>
        <a data-w-id="94f27a2e-4400-60a5-89bb-b8e69cc3133e" href="/sobre-mi" class="cta base__white full-width w-inline-block">
          <p class="wysiwyg cta-text dark__type">Próximamente</p>
          <div class="cta-circle"></div>
        </a>
      </div>
      <div class="hero_project_info">
        <div class="hero_project_info_description text-colour-white">Nosotras no seguimos reglas, las creamos. Esta es la moda para chicas que no tienen miedo de ser auténticas, libres y rebeldes. Cada prenda es una declaración, diseñada para la generación que vive sin filtros, con actitud y estilo único. ¿Lista para destacar sin pedir permiso?</div>
        <div class="u-hflex-between-top zig-mobile">
          <div class="hero-project_info-list">
            <div class="info-list_heading text-colour-white">Cliente</div>
            <div class="info-list_item text-colour-white">Basica&amp;Co</div>
          </div>
          <div class="hero-project_info-list">
            <div class="info-list_heading text-colour-white">Services</div>
            <div class="info-list_item text-colour-white">CRO</div>
            <div class="info-list_item text-colour-white">UX &amp; UI Design</div>
            <div class="info-list_item text-colour-white">Behavioral Design</div>
            <div class="info-list_item text-colour-white">Visual Design</div>
          </div>
          <div class="hero-project_info-list">
            <div class="info-list_heading text-colour-white">Industria</div>
            <div class="info-list_item text-colour-white">Moda</div>
            <div class="info-list_item text-colour-white">Star-up</div>
          </div>
          <div class="hero-project_info-list">
            <div class="info-list_heading text-colour-white">Fecha</div>
            <div class="info-list_item text-colour-white">Octubre 2024</div>
          </div>
        </div>
      </div>
    </div><img src="/images/hero-image_1.avif" loading="lazy" sizes="100vw" srcset="/images/hero-image_1hero-image.avif 500w, /images/hero-image_1hero-image.avif 800w, /images/hero-image_1.avif 1792w" alt="Basica &amp; Co — imagen de portada del proyecto" class="hero_project_bg" />
  </section>
  <section class="desktop_description">
    <div class="description_text_objetive fade-in">
      <h2 class="description_text_objetive_heading">E-commerce de moda urbana dirigida exclusivamente para mujeres</h2>
      <div class="u-hflex-between-top full_width">
        <div class="description_title"><img src="/images/diamond.svg" loading="lazy" alt="" class="description_title_image" />
          <div class="description_title_name">Objetivos</div>
        </div>
        <div class="description_wrapper">
          <div class="description_paragraph">En este proyecto el objetivo principal era diseñar un e-commerce de moda que relfejase fielmente los valores de marca de la misma, optimizando y haciendo especial foco en la conversión, utilizando las últimas tendencias en Behavioral design y CRO, para optimizar la conversión.</div>
          <div class="description_paragraph">Encontrar el balance justo entre impacto visual, valores de marca y a la vez una UX muy trabajada y orientada a la conversión  fue el reto principal que nos propuso el cliente y que nos enfrentamos en este proyecto.</div>
        </div>
      </div>
    </div>
    <div data-w-id="8efec8fe-c4ac-2809-0cd8-c5d2a4d5fce0" class="description_carousel">
      <div class="description_carousel_upperrow fade-in"><img src="/images/coleccion-alemana_1.avif" loading="lazy" sizes="100vw" srcset="/images/coleccion-alemana_1coleccion-alemana.avif 500w, /images/coleccion-alemana_1coleccion-alemana.avif 800w, /images/coleccion-alemana_1.avif 1550w" alt="Colección alemana de Basica &amp; Co" class="upper-row-image is1" /><img src="/images/chica-japonesa-traje-azul_1.avif" loading="lazy" sizes="100vw" srcset="/images/chica-japonesa-traje-azul_1chica-japonesa-traje-azul.avif 500w, /images/chica-japonesa-traje-azul_1.avif 1400w" alt="Modelo con look azul de Basica &amp; Co" class="upper-row-image is2" /><img src="/images/coleccion-brasil_1.avif" loading="lazy" sizes="100vw" srcset="/images/coleccion-brasil_1coleccion-brasil.avif 500w, /images/coleccion-brasil_1.avif 1018w" alt="Colección Brasil de Basica &amp; Co" class="upper-row-image is3" /><img src="/images/coleccion-japonesa_1.avif" loading="lazy" sizes="100vw" srcset="/images/coleccion-japonesa_1coleccion-japonesa.avif 500w, /images/coleccion-japonesa_1coleccion-japonesa.avif 800w, /images/coleccion-japonesa_1.avif 1739w" alt="Colección japonesa de Basica &amp; Co" class="upper-row-image is4" /><img src="/images/coleccionroja_1.avif" loading="lazy" sizes="100vw" srcset="/images/coleccionroja_1coleccionroja.avif 500w, /images/coleccionroja_1.avif 1200w" alt="Colección roja de Basica &amp; Co" class="upper-row-image is5" /></div>
      <div class="description_carousel_bottomrow"><img src="/images/camisetaroja_1.avif" loading="lazy" sizes="100vw" srcset="/images/camisetaroja_1camisetaroja.avif 500w, /images/camisetaroja_1.avif 826w" alt="Camiseta roja de Basica &amp; Co" class="bottom-row-image is1" /><img src="/images/creadoras_1.avif" loading="lazy" alt="Creadoras de Basica &amp; Co" class="upper-row-image-copy is2" /><img src="/images/camisetamarilla_1.avif" loading="lazy" sizes="100vw" srcset="/images/camisetamarilla_1camisetamarilla.avif 500w, /images/camisetamarilla_1camisetamarilla.avif 800w, /images/camisetamarilla_1.avif 1733w" alt="Camiseta amarilla de Basica &amp; Co" class="bottom-row-image is3" /><img src="/images/cross-shirt_1.avif" loading="lazy" sizes="100vw" srcset="/images/cross-shirt_1cross-shirt.avif 500w, /images/cross-shirt_1.avif 992w" alt="Camiseta de Basica &amp; Co" class="bottom-row-image is4" /><img src="/images/coleccionroja_1.avif" loading="lazy" sizes="100vw" srcset="/images/coleccionroja_1coleccionroja.avif 500w, /images/coleccionroja_1.avif 1200w" alt="Colección roja de Basica &amp; Co" class="upper-row-image is5" /></div>
    </div>
    <div class="description_text_solucion fade-in">
      <h2 class="description_text_objetive_heading">Behavioral design</h2>
      <div class="u-hflex-between-top full_width">
        <div class="description_title"><img src="/images/diamond.svg" loading="lazy" alt="" class="description_title_image" />
          <div class="description_title_name">Soluciones</div>
        </div>
        <div class="description_wrapper">
          <div class="description_paragraph">Aplicamos principios básicos de Behavioral design:</div>
          <div class="description_paragraph"><strong>1.-Prueba social: </strong>en nuestro producto, al ser una marca nueva esto era necesario para nuestros compradores potenciales.<br /><strong>2.-Sesgo de anclaje:</strong> Cuando realizamos un descuento en un producto lo mostramos para reforzar el valor del mejor precio<br /><strong>3.-Distanciar precio-CTA:</strong> En nuestro diseño hemos distanciado el precio del CTA de conversión, dado que este siempre es un punto que dificulta la conversión<br /><strong>4.-Facilitación cognitiva: </strong>Simplificamos el proceso de compra con botones grandes, opciones preseleccionadas y recomendaciones personalizadas. El cerebro tiende a elegir el camino de menor esfuerzo.</div>
        </div>
      </div>
    </div>
    <div class="description-2columns">
      <div class="description_2columns_wrapper">
        <div class="description_text_solucion u-desktop-25vw">
          <div class="u-vflex-left-top fade-in">
            <div class="description_title u-pad-botm-1"><img src="/images/diamond.svg" loading="lazy" alt="" class="description_title_image" />
              <div class="description_title_name">Behavioral design y UX en PDP</div>
            </div>
            <div class="description_wrapper">
              <div class="description_paragraph">Como podemos observar en la PDP hemos aplicado las siguientes best-practice:</div>
              <div class="description_paragraph"><strong>1.-Prueba social: </strong>en nuestro producto, al ser una marca nueva esto era necesario para nuestros compradores potenciales utilizamos calificaciones y opiniones de compradores.<br /><strong>2.-Sesgo de anclaje:</strong> Cuando realizamos un descuento en un producto lo mostramos para reforzar el valor del mejor precio y eliminar dicha fricción del comprador.<br /><strong>3.-Distanciar precio-CTA:</strong> En nuestro diseño hemos distanciado el precio del CTA de conversión, dado que este siempre es un punto que dificulta la conversión, manteniendo en un lugar jerárquico predominante las acciones de conversión.<br /><strong>4.-Facilitación cognitiva: </strong>Simplificamos el proceso de compra con botones grandes, opciones preseleccionadas y recomendaciones personalizadas. El cerebro tiende a elegir el camino de menor esfuerzo.</div>
            </div>
          </div>
        </div>
        <div class="description_image_solution u-desktop-50vw"><img src="/images/pdp_1.avif" loading="lazy" sizes="100vw" srcset="/images/pdp_1pdp.avif 500w, /images/pdp_1pdp.avif 800w, /images/pdp_1.avif 1801w" alt="Página de producto (PDP) de Basica &amp; Co" class="shadow--medium" /></div>
      </div>
    </div>
    <div class="description-2columns">
      <div class="description_2columns_wrapper">
        <div class="description_image_solution u-desktop-50vw"><img src="/images/PLPdesktop_1.avif" loading="lazy" sizes="100vw" srcset="/images/PLPdesktop_1PLPdesktop.avif 500w, /images/PLPdesktop_1.avif 1200w" alt="Página de listado de productos (PLP) de Basica &amp; Co" class="shadow--medium" /></div>
        <div class="description_text_solucion u-desktop-25vw">
          <div class="u-vflex-left-top fade-in">
            <div class="description_title u-pad-botm-1"><img src="/images/diamond.svg" loading="lazy" alt="" class="description_title_image" />
              <div class="description_title_name">Behavioral design y UX en PLP</div>
            </div>
            <div class="description_wrapper">
              <div class="description_paragraph">Hemos hecho especial foco en la PLp en mantener el atractivo de nuestro diseño con la posibilidad de facilitar la conversión:</div>
              <div class="description_paragraph"><strong>1.-Jerarquización de filtros:</strong> Hemos mantenido el filtro principal de forma accesible a nuestros usuario, y las opciones con menos interacción dentro del menú de filtros<br /><strong>2.-Quick add to cart: </strong>He generado una propuesta donde es muy sencillo añadir y configurar tu producto sin necesidad de acceder a la PDP, acortando el camino hacia la conversión<br /><strong>3.-Priorización visual:</strong> Hemos optado por un diseño donde los productos e imágenes de tan grande impacto visual fueran esenciales.<br /><strong>4.-Facilitación cognitiva:</strong> Simplificamos el proceso de compra con botones grandes, opciones preseleccionadas y recomendaciones personalizadas. El cerebro tiende a elegir el camino de menor esfuerzo.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div data-w-id="b4dff865-1127-41f6-f380-346867ec2a6a" class="description_2image"><img src="/images/Desktop_1.avif" loading="lazy" data-w-id="96eb5176-a2ea-06e6-63c6-6047ecd0225c" sizes="100vw" alt="Diseño de la web de Basica &amp; Co" srcset="/images/Desktop_1Desktop.avif 500w, /images/Desktop_1Desktop.avif 800w, /images/Desktop_1.avif 1604w" class="description_image is1 shadow--medium" /><img src="/images/Desktop-1.avif" loading="lazy" sizes="100vw" srcset="/images/Desktop-1-p-500.avif 500w, /images/Desktop-1-p-800.avif 800w, /images/Desktop-1-p-1080.avif 1080w, /images/Desktop-1.avif 1439w" alt="Diseño de la web de Basica &amp; Co" class="description_image is2 shadow--medium" /></div>
    <div class="description_text_objetive fade-in">
      <div class="text_objetive_wrapper">
        <div class="w-layout-grid grid">
          <div class="description_paragraph"></div>
          <h2 id="w-node-_1534a6e6-c4d9-92ba-ea21-3ea127f34b53-99783c08" class="description_text_objetive_heading">Un mundo de exploración sin límites</h2>
          <div class="description_paragraph">
            <div class="description_title"><img src="/images/diamond.svg" loading="lazy" alt="" class="description_title_image" />
              <div class="description_title_name">Visual </div>
            </div>
          </div>
          <div class="description_paragraph">Diseñé un espacio para inspirar la exploración y el descubrimiento, permitiendo que el contenido fluya con naturalidad desde vistas generales hasta los detalles más minuciosos. Este diseño transmite la sensación de recorrer un mundo, en lugar de simplemente navegar por una web convencional.</div>
        </div>
      </div>
    </div>
    <section data-w-id="38e500b2-9991-8d38-97e5-dc7a07af6579" class="description-zoom-transition">
      <div class="sticky-container">
        <div id="w-node-_38e500b2-9991-8d38-97e5-dc7a07af657b-99783c08" class="w-layout-layout quick-stack wf-layout-layout">
          <div id="w-node-_38e500b2-9991-8d38-97e5-dc7a07af657c-99783c08" class="w-layout-cell"></div>
          <div class="w-layout-cell"></div>
          <div id="w-node-_38e500b2-9991-8d38-97e5-dc7a07af657d-99783c08" class="w-layout-cell cell-2"><img sizes="100vw" srcset="/images/girls_1girls.avif 500w, /images/girls_1girls.avif 800w, /images/girls_1girls.avif 1080w, /images/girls_1.avif 2029w" alt="Modelos de campaña de Basica &amp; Co" src="/images/girls_1.avif" loading="lazy" class="fading-image" /></div>
          <div class="w-layout-cell"></div>
          <div id="w-node-_38e500b2-9991-8d38-97e5-dc7a07af657f-99783c08" class="w-layout-cell cell"><img sizes="100vw" srcset="/images/camisaazul-vertical_1camisaazul-vertical.avif 500w, /images/camisaazul-vertical_1.avif 1200w" alt="Camisa azul de Basica &amp; Co" src="/images/camisaazul-vertical_1.avif" loading="lazy" class="fading-image half" /></div>
          <div id="w-node-_38e500b2-9991-8d38-97e5-dc7a07af6581-99783c08" class="w-layout-cell cell-3">
            <div class="main-image-wrapper"><img sizes="100vw" srcset="/images/visualelectric-1729791413747_1visualelectric-1729791413747.avif 500w, /images/visualelectric-1729791413747_1visualelectric-1729791413747.avif 800w, /images/visualelectric-1729791413747_1visualelectric-1729791413747.avif 1080w, /images/visualelectric-1729791413747_1.avif 2560w" alt="" src="/images/visualelectric-1729791413747_1.avif" loading="lazy" class="main-image" /></div>
          </div>
          <div id="w-node-_38e500b2-9991-8d38-97e5-dc7a07af6584-99783c08" class="w-layout-cell"><img sizes="100vw" srcset="/images/chica-basica_1chica-basica.avif 500w, /images/chica-basica_1.avif 1401w" alt="Modelo de campaña de Basica &amp; Co" src="/images/chica-basica_1.avif" loading="lazy" class="fading-image" /></div>
          <div id="w-node-_38e500b2-9991-8d38-97e5-dc7a07af6586-99783c08" class="w-layout-cell"></div>
          <div class="w-layout-cell"><img sizes="100vw" srcset="/images/open-party_1open-party.avif 500w, /images/open-party_1.avif 951w" alt="Campaña Open Party de Basica &amp; Co" src="/images/open-party_1.avif" loading="lazy" class="fading-image" /></div>
          <div id="w-node-_38e500b2-9991-8d38-97e5-dc7a07af6588-99783c08" class="w-layout-cell"></div>
        </div>
      </div>
    </section>
    <div class="transition_responsive"><img src="/images/visualelectric-1729791413747_1.avif" loading="lazy" sizes="100vw" srcset="/images/visualelectric-1729791413747_1visualelectric-1729791413747.avif 500w, /images/visualelectric-1729791413747_1visualelectric-1729791413747.avif 800w, /images/visualelectric-1729791413747_1visualelectric-1729791413747.avif 1080w, /images/visualelectric-1729791413747_1.avif 2560w" alt="" class="transition_responsive_image" /></div>
  </section>
  <div class="mobile_description">
    <div class="description_text_objetive fade-in">
      <h2 class="description_text_objetive_heading">Especial foco en el diseño responsive</h2>
      <div class="u-hflex-between-top full_width">
        <div class="description_title"><img src="/images/diamond-white.svg" loading="lazy" alt="" class="description_title_image" />
          <div class="description_title_name">Responsive</div>
        </div>
        <div class="description_wrapper">
          <div class="description_paragraph">La inmensa mayoría de los usuarios acceden al mundo del e-commerce mediante dispositivos móbiles, por ello realicé especial foco en generr un diseño adaptado, intuitivo y precognitivo, para poder guiar al usuario de forma suave hacia nuestro objetivo: la conversión.</div>
          <div class="description_paragraph">En el formato mobile estudiamos todas las tendencias del mercado para poder traerle una UX siguiendo todos los requerimientos necesarios y a la vez una UI visualmente potente y consistente.</div>
        </div>
      </div>
    </div>
    <div data-w-id="7e4134f3-aada-56d5-587b-d53583cb04fb" class="mobile_show_images"><img src="/images/model_1.avif" loading="lazy" alt="Modelo de campaña de Basica &amp; Co" class="mobile_show_image_bg" />
      <div data-w-id="1acbc6f4-03b9-8609-7b29-cf5789da5879" class="mobile_show_image_wrapper"><img src="/images/Mobile_1.avif" loading="lazy" alt="Versión móvil de la web de Basica &amp; Co" class="mobile_show_image is1" /><img src="/images/PDPmobile_1.avif" loading="lazy" alt="Versión móvil de la página de producto de Basica &amp; Co" class="mobile_show_image is2" /><img src="/images/PDPresponsive_1.avif" loading="lazy" alt="Versión móvil de la página de producto de Basica &amp; Co" class="mobile_show_image is3" /></div>
    </div>
    <div class="description-2columns">
      <div class="description_2columns_wrapper">
        <div class="description_text_solucion u-desktop-25vw">
          <div class="u-vflex-left-top fade-in">
            <div class="description_title u-pad-botm-1"><img src="/images/diamond-white.svg" loading="lazy" alt="" class="description_title_image" />
              <div class="description_title_name">Diseño mobile</div>
            </div>
            <div class="description_wrapper">
              <div class="description_paragraph">Como podemos observar en la PDP hemos aplicado las siguientes best-practice:</div>
              <div class="description_paragraph"><strong>1.-Diseño adaptado:  </strong>utilizamos un posicionamiento y ordenación de elementos adaptados al formato mobile<br /><strong>2.-Escalabilidad:</strong> A la hora de diseñar un proyecto así, es importante la escalabilidad del sistema visual que creemos, para así poder construir un producto digital perdurable<br /><strong>3.-Adaptación de imágenes:</strong> En Basica&amp;Co, hemos rediseñado todos los elementos en formato mobile para que se adapten a dicha interfaz, incluidas recomendaciones sobre la selección de imágenes<br /><strong>4.-Facilitación cognitiva: </strong>Simplificamos el proceso de compra con botones grandes, opciones preseleccionadas y recomendaciones personalizadas. El cerebro tiende a elegir el camino de menor esfuerzo.<br /><strong>5.-Sticky CTA: </strong>Nuestro usuario tiene a mano en todo momento el CTA de conversión y la posibilidad de configurar el producto, las acciones principales siempre a mano.</div>
            </div>
          </div>
        </div>
        <div class="description_image_solution u-desktop-50vw"><img src="/images/PDPresponsive_1.avif" loading="lazy" alt="Versión móvil de la página de producto de Basica &amp; Co" class="description_image_solution_mobile is1" /><img src="/images/PDP-1.avif" loading="lazy" alt="Página de producto de Basica &amp; Co" class="description_image_solution_mobile is2" /></div>
      </div>
    </div>
    <div class="description-2columns">
      <div class="description_2columns_wrapper">
        <div class="description_image_solution u-desktop-50vw"><img src="/images/PLP.avif" loading="lazy" alt="Página de listado de productos de Basica &amp; Co" class="description_image_solution_mobile is2" /><img src="/images/PLP-1.avif" loading="lazy" alt="Página de listado de productos de Basica &amp; Co" class="description_image_solution_mobile" /></div>
        <div class="description_text_solucion u-desktop-25vw">
          <div class="u-vflex-left-top fade-in">
            <div class="description_title u-pad-botm-1"><img src="/images/diamond-white.svg" loading="lazy" alt="" class="description_title_image" />
              <div class="description_title_name">Behavioral design y UX en PLP</div>
            </div>
            <div class="description_wrapper">
              <div class="description_paragraph">Hemos hecho especial foco en la PLp en mantener el atractivo de nuestro diseño con la posibilidad de facilitar la conversión:</div>
              <div class="description_paragraph"><strong>1.-Jerarquización de filtros:</strong> Hemos mantenido el filtro principal de forma accesible a nuestros usuario, y las opciones con menos interacción dentro del menú de filtros<br /><strong>2.-Quick add to cart:</strong> He generado una propuesta donde es muy sencillo añadir y configurar tu producto sin necesidad de acceder a la PDP, acortando el camino hacia la conversión<br /><strong>3.-Priorización visual: </strong>Hemos optado por un diseño donde los productos e imágenes de tan grande impacto visual fueran esenciales.<br /><strong>4.-Facilitación cognitiva:</strong> Simplificamos el proceso de compra con botones grandes, opciones preseleccionadas y recomendaciones personalizadas. El cerebro tiende a elegir el camino de menor esfuerzo.</div>
            </div>
          </div>
        </div>
