# Resend API key for the contact form (server-side only).
# 1. Create a free account at https://resend.com
# 2. Verify the domain "mrmoises.es" (Resend > Domains > Add Domain) by adding
#    the SPF/DKIM DNS records it shows you. This lets you send from @mrmoises.es.
# 3. Create an API key (Resend > API Keys) and paste it below.
# 4. In Vercel, add this same variable under Project > Settings > Environment Variables.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
